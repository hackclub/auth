<% first = @identity.legal_first_name.presence || @identity.first_name %>
<% last = @identity.legal_last_name.presence || @identity.last_name %>
<% verf = @identity.persona_verifications.where(status: :draft).first %>
<% if verf %>
  <div class="persona-name-check">
    <p x-show="!editingName">
      Verifying as <strong><%= first %> <%= last %></strong>
      &middot;
      <a href="#" @click.prevent="editingName = true">not what's on your ID?</a>
    </p>

    <div x-show="editingName" x-cloak>
      <%= form_with url: local_assigns[:form_url] || update_legal_name_path, method: :patch, local: true,
            html: { class: "persona-name-form" } do |f| %>
        <p>Enter the name as it appears on your ID</p>
        <div class="persona-name-fields">
          <%= f.text_field :legal_first_name, value: first, required: true, autocomplete: "given-name", placeholder: "First name" %>
          <%= f.text_field :legal_last_name, value: last, required: true, autocomplete: "family-name", placeholder: "Last name" %>
        </div>
        <div class="persona-name-actions">
          <%= f.submit "Update", class: "secondary" %>
          <a href="#" @click.prevent="editingName = false">cancel</a>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<section class="section-card">
  <div class="status-indicator">
    <span class="status-badge pending"><%= t("verifications.status.badges.under_review") %></span>
    <h3><%= t("verifications.status.pending_document.title") %></h3>
    <p><%= t("verifications.status.pending_document.subtitle") %></p>
  </div>

  <div class="status-content">
    <p><%= t("verifications.status.pending_document.description", email: identity.primary_email) %></p>

    <% if verification.present? %>
      <div class="meta">
        <%= t("verifications.status.pending_document.submitted_ago", time: time_ago_in_words(verification.created_at)) %>
        <% if verification.document_type_label.present? %>
          &middot; <%= verification.document_type_label %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<div class="page-header">
  <h1><%= t(".title") %></h1>
  <p><%= t(".subtitle") %></p>
</div>

<div class="page-sections">
  <% if @persona_error %>
    <section class="section-card">
      <p><%= @persona_error %></p>
      <p>
        <a href="<%= verification_step_path(:document) %>"><%= t(".fallback_link") %></a>
      </p>
    </section>
  <% else %>
    <section class="section-card"
             data-persona-verify
             data-inquiry-id="<%= @inquiry_id %>"
             data-session-token="<%= @session_token %>"
             data-environment-id="<%= @environment_id %>"
             data-host="<%= @persona_host %>"
             data-status-url="<%= verification_status_path %>"
             data-msg-complete="<%= t(".complete_message") %>"
             data-msg-cancel="<%= t(".cancel_message") %>"
             data-msg-error="<%= t(".error_sdk") %>">

      <p data-persona-message></p>

      <button data-persona-start type="button" is="button" variant-="primary">
        <%= t(".begin_verification") %>
      </button>

      <p style="margin-top: 2lh; color: var(--foreground2); font-size: 0.9em;">
        <%= t(".cant_do_this") %>
        <a href="<%= verification_step_path(:document) %>"><%= t(".fallback_prompt") %></a>
      </p>
    </section>
  <% end %>
</div>

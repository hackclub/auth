<column pad-="2 1" style="max-width: 80ch; margin: 0 auto; width: 100%;">
  <h2>deletion #<%= @deletion.id %></h2>

  <div is-="separator"></div>

  <table>
    <tbody>
      <tr>
        <th style="text-align: left;">reference</th>
        <td><%= @deletion.privacy_request_reference.presence || "—" %></td>
      </tr>
      <tr>
        <th style="text-align: left;">created</th>
        <td><%= @deletion.created_at.strftime("%Y-%m-%d %H:%M UTC") %></td>
      </tr>
      <tr>
        <th style="text-align: left;">name combo hashes</th>
        <td><%= @deletion.name_combos.size %></td>
      </tr>
      <tr>
        <th style="text-align: left;">session IP hashes</th>
        <td><%= @deletion.session_ips.size %></td>
      </tr>
    </tbody>
  </table>
</column>

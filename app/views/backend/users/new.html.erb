<column pad-="2 1" style="max-width: 80ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2>grant backend access</h2>
    <a href="<%= backend_users_path %>" style="color: var(--foreground2); text-decoration: none;">cancel</a>
  </row>

  <div is-="separator"></div>

  <%= form_with url: new_backend_user_path, method: :get, local: true do |f| %>
    <row gap-="1" align-="center">
      <span style="color: var(--foreground2);">⌕</span>
      <%= f.text_field :query, placeholder: "find identity by email, name, or slack id...", value: params[:query], autofocus: true, style: "flex: 1; border: none;" %>
      <button type="submit" size-="small">search</button>
    </row>
  <% end %>

  <% if params[:query].present? %>
    <div is-="separator"></div>
    <% if @identities.any? %>
      <column box-="square">
        <% @identities.each do |identity| %>
          <a href="<%= new_backend_user_path(identity_id: identity.id) %>" data-navigable-item style="padding: 0 1ch;">
            <b style="min-width: 20ch;"><%= identity.first_name %> <%= identity.last_name %></b>
            <span style="flex: 1; color: var(--foreground2);"><%= identity.primary_email %></span>
            <span style="color: var(--foreground2);">select →</span>
          </a>
        <% end %>
      </column>
    <% else %>
      <span style="color: var(--foreground2);">no identities matching "<%= params[:query] %>"</span>
    <% end %>
  <% end %>

  <% if params[:identity_id].present? %>
    <% identity = Identity.find(params[:identity_id]) %>
    <div is-="separator"></div>

    <column box-="square">
      <b><%= identity.first_name %> <%= identity.last_name %></b>
      <span style="color: var(--foreground2);"><%= identity.primary_email %></span>
    </column>

    <%= form_with url: backend_users_path, method: :post, local: true do |f| %>
      <%= hidden_field_tag :identity_id, identity.id %>
      <div is-="separator"></div>
      <%= render "backend/shared/permissions_form", f: f, user: Backend::User.new %>
      <div is-="separator"></div>
      <button type="submit">grant access</button>
    <% end %>
  <% end %>
</column>

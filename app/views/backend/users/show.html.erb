<column pad-="2 1" style="max-width: 80ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2><%= @user.display_name %></h2>
    <row gap-="1" align-="center">
      <% super_admin_tool do %>
        <a href="<%= edit_backend_user_path(@user) %>"><button size-="small">edit</button></a>
        <% if @user.active? %>
          <%= button_to "deactivate", deactivate_backend_user_path(@user), method: :post, size: "small" %>
        <% else %>
          <%= button_to "activate", activate_backend_user_path(@user), method: :post, size: "small" %>
        <% end %>
      <% end %>
    </row>
  </row>

  <% if @user.orphaned? %>
    <div box-="square" class="tui-banner tui-banner-warning">[!] orphaned — not linked to an identity, cannot log in</div>
  <% end %>

  <div is-="separator"></div>

  <% unless @user.orphaned? %>
    <row gap-="3">
      <column style="flex: 1;">
        <span style="color: var(--foreground2);">identity</span>
        <span><%= @user.first_name %> <%= @user.last_name %></span>
        <span style="color: var(--foreground2);"><%= @user.email %></span>
        <% if @user.slack_id %>
          <span style="color: var(--foreground2);">slack: <%= @user.slack_id %></span>
        <% end %>
      </column>
      <column style="flex: 1;">
        <span style="color: var(--foreground2);">permissions</span>
        <span><%= @user.pretty_roles %></span>
        <% if @user.organized_programs.any? %>
          <span style="color: var(--foreground2);">programs: <%= @user.organized_programs.map(&:name).join(", ") %></span>
        <% end %>
      </column>
    </row>
  <% end %>

  <div is-="separator"></div>

  <row gap-="2" align-="center" style="color: var(--foreground2);">
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">Bksp</span>
      back
    </row>
  </row>
</column>

<div class="tui-page">
  <article box-="round">
    <h2>edit: <%= @identity.first_name %> <%= @identity.last_name %></h2>
    <div is-="separator"></div>
    <a href="<%= backend_identity_path(@identity) %>" class="tui-item">
      <span class="tui-item-icon">&#x2b60;</span>
      <span class="tui-item-text"><b>cancel</b></span>
    </a>
    <div is-="separator"></div>
    <% if @identity.errors.any? %>
      <div box-="square" class="tui-banner tui-banner-warning">
        [!] <%= pluralize(@identity.errors.count, "error") %>:
        <% @identity.errors.full_messages.each do |message| %>
          <%= message %>.
        <% end %>
      </div>
      <div is-="separator"></div>
    <% end %>
    <%= form_with model: [@identity], url: backend_identity_path(@identity), method: :patch, local: true do |f| %>
      <h3>identity</h3>
      <div>
        <%= f.label :first_name %>
        <%= f.text_field :first_name %>
      </div>
      <div>
        <%= f.label :last_name %>
        <%= f.text_field :last_name %>
      </div>
      <div>
        <%= f.label :legal_first_name, "legal first" %>
        <%= f.text_field :legal_first_name %>
      </div>
      <div>
        <%= f.label :legal_last_name, "legal last" %>
        <%= f.text_field :legal_last_name %>
      </div>
      <div>
        <%= f.label :primary_email, "email" %>
        <%= f.email_field :primary_email %>
      </div>
      <div>
        <%= f.label :phone_number, "phone" %>
        <%= f.telephone_field :phone_number %>
      </div>
      <div>
        <%= f.label :birthday, "dob" %>
        <%= f.date_field :birthday %>
      </div>
      <div>
        <%= f.label :country %>
        <%= f.select :country, options_for_select(Identity.countries_for_select.map {|code, name| [name, code]}, @identity.country), { prompt: "select..." } %>
      </div>

      <div is-="separator"></div>

      <h3>overrides</h3>
      <div>
        <%= f.label :hq_override, "hq override" %>
        <%= f.check_box :hq_override %>
        <small>bypass normal eligibility rules</small>
      </div>
      <div>
        <%= f.label :ysws_eligible, "ysws eligible" %>
        <%= f.check_box :ysws_eligible %>
      </div>
      <% super_admin_tool do %>
        <div>
          <%= f.label :permabanned %>
          <%= f.check_box :permabanned %>
          <small>permanently ban (makes ineligible)</small>
        </div>
        <div>
          <%= f.label :can_hq_officialize, "can officialize apps" %>
          <%= f.check_box :can_hq_officialize %>
          <small>allow this identity to promote apps to hq_official</small>
        </div>
      <% end %>

      <div is-="separator"></div>

      <h3>reason for change</h3>
      <%= text_area_tag :reason, params[:reason], placeholder: "required - will be logged in audit trail", rows: 3 %>

      <div is-="separator"></div>

      <div style="display:flex;gap:1ch;">
        <a href="<%= backend_identity_path(@identity) %>"><button type="button">CANCEL</button></a>
        <%= f.submit "save" %>
      </div>
    <% end %>

    <div is-="separator"></div>

    <div box-="square" class="tui-banner tui-banner-warning">[!] break glass access required. all changes are permanently logged.</div>

    <div is-="separator"></div>

    <% if @identity.slack_id.present? %>
      <%= button_to clear_slack_id_backend_identity_path(@identity), class: "tui-item" do %>
        <span class="tui-item-icon">&#x2715;</span>
        <span class="tui-item-text"><b>clear slack id</b></span>
      <% end %>
    <% else %>
      <%= button_to reprovision_slack_backend_identity_path(@identity), class: "tui-item" do %>
        <span class="tui-item-icon">+</span>
        <span class="tui-item-text"><b>provision slack account</b></span>
      <% end %>
    <% end %>
  </article>
</div>

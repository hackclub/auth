<column pad-="2 1" style="max-width: 80ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2>edit: <%= @identity.first_name %> <%= @identity.last_name %></h2>
    <a href="<%= backend_identity_path(@identity) %>" style="color: var(--foreground2); text-decoration: none;">cancel</a>
  </row>

  <div box-="square" class="tui-banner tui-banner-warning">[!] break glass access required. all changes are permanently logged.</div>

  <% if @identity.errors.any? %>
    <div box-="square" class="tui-banner tui-banner-danger">
      [!] <%= pluralize(@identity.errors.count, "error") %>:
      <% @identity.errors.full_messages.each do |message| %>
        <%= message %>.
      <% end %>
    </div>
  <% end %>

  <div is-="separator"></div>

  <%= form_with model: [@identity], url: backend_identity_path(@identity), method: :patch, local: true do |f| %>
    <column gap-="1">
      <span style="color: var(--foreground2);">identity</span>
      <row gap-="2">
        <column style="flex: 1;"><%= f.label :first_name %><%= f.text_field :first_name %></column>
        <column style="flex: 1;"><%= f.label :last_name %><%= f.text_field :last_name %></column>
      </row>
      <row gap-="2">
        <column style="flex: 1;"><%= f.label :legal_first_name, "legal first" %><%= f.text_field :legal_first_name %></column>
        <column style="flex: 1;"><%= f.label :legal_last_name, "legal last" %><%= f.text_field :legal_last_name %></column>
      </row>
      <column><%= f.label :primary_email, "email" %><%= f.email_field :primary_email %></column>
      <column><%= f.label :phone_number, "phone" %><%= f.telephone_field :phone_number %></column>
      <row gap-="2">
        <column style="flex: 1;"><%= f.label :birthday, "dob" %><%= f.date_field :birthday %></column>
        <column style="flex: 1;"><%= f.label :country %><%= f.select :country, options_for_select(Identity.countries_for_select.map {|code, name| [name, code]}, @identity.country), { prompt: "select..." } %></column>
      </row>

      <div is-="separator"></div>

      <span style="color: var(--foreground2);">overrides</span>
      <label><%= f.check_box :hq_override %> hq override <span style="color: var(--foreground2);">— bypass normal eligibility rules</span></label>
      <label><%= f.check_box :ysws_eligible %> ysws eligible</label>
      <% super_admin_tool do %>
        <label><%= f.check_box :permabanned %> permabanned <span style="color: var(--foreground2);">— permanently ban</span></label>
        <label><%= f.check_box :can_hq_officialize %> can officialize apps</label>
      <% end %>

      <div is-="separator"></div>

      <span style="color: var(--foreground2);">reason for change</span>
      <%= text_area_tag :reason, params[:reason], placeholder: "required — will be logged in audit trail", rows: 3 %>

      <div is-="separator"></div>

      <row gap-="1">
        <%= f.submit "save" %>
        <a href="<%= backend_identity_path(@identity) %>"><button type="button">cancel</button></a>
      </row>
    </column>
  <% end %>

  <div is-="separator"></div>

  <span style="color: var(--foreground2);">danger zone</span>
  <row gap-="1">
    <% if @identity.slack_id.present? %>
      <%= button_to "clear slack id", clear_slack_id_backend_identity_path(@identity), size: "small" %>
    <% else %>
      <%= button_to "provision slack", reprovision_slack_backend_identity_path(@identity), size: "small" %>
    <% end %>
  </row>
</column>

<column pad-="2 1" style="max-width: 80ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2>vouch for <%= @identity.first_name %> <%= @identity.last_name %></h2>
    <a href="<%= backend_identity_path(@identity) %>" style="color: var(--foreground2); text-decoration: none;">cancel</a>
  </row>

  <div is-="separator"></div>

  <%= form_with model: [@identity, @vouch], url: create_vouch_backend_identity_path(@identity), method: :post, local: true do |f| %>
    <column gap-="1">
      <column>
        <%= f.label :evidence, "upload evidence" %>
        <%= f.file_field :evidence, required: true %>
      </column>
      <div is-="separator"></div>
      <button type="submit">create vouch</button>
    </column>
  <% end %>
</column>

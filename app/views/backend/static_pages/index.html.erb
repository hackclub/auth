<column self-="grow" align-="center center" style="min-height: calc(100vh - 3lh);">
  <column box-="round" style="min-width: 56ch; max-width: 72ch;">
    <row align-="center between">
      <span is-="badge" variant-="lavender" cap-="round">HCA</span>
      <span style="color: var(--overlay1);"><%= current_user.display_name %> · <%= current_user.pretty_roles %></span>
    </row>

    <div is-="separator"></div>

    <column data-navigable-list>
      <% if current_user.super_admin? %>
        <details open>
          <summary>Super admin</summary>
          <ul>
            <a href="<%= backend_flipper_path %>" data-navigable-item>
              Flipper <i style="color: var(--overlay0);">(i hardly know 'er!)</i>
              <span is-="badge" variant-="background2" cap-="round" style="float: right;">FLIP</span>
            </a>
            <a href="<%= backend_audits1984_path %>" data-navigable-item>
              Audits1984
              <span is-="badge" variant-="background2" cap-="round" style="float: right;">ORWL</span>
            </a>
            <a href="<%= backend_good_job_path %>" data-navigable-item>
              Job queue
              <span is-="badge" variant-="background2" cap-="round" style="float: right;">JOBS</span>
            </a>
            <a href="<%= backend_users_path %>" data-navigable-item>
              Manage users
              <span is-="badge" variant-="background2" cap-="round" style="float: right;">USRS</span>
            </a>
          </ul>
        </details>
      <% end %>

      <% if current_user&.program_manager? || current_user&.super_admin? %>
        <details open>
          <summary>Program manager</summary>
          <ul>
            <a href="<%= developer_apps_path %>" data-navigable-item>
              Manage OAuth2 apps
              <span is-="badge" variant-="background2" cap-="round" style="float: right;">APPS</span>
            </a>
          </ul>
        </details>
      <% end %>

      <% if current_user&.manual_document_verifier? || current_user&.super_admin? %>
        <details open>
          <summary>Document verifier</summary>
          <ul>
            <a href="<%= pending_backend_verifications_path %>" data-navigable-item>
              Review pending verifications
              <span is-="badge" variant-="peach" cap-="round" style="float: right;">PEND</span>
            </a>
          </ul>
        </details>
      <% end %>

      <div is-="separator"></div>

      <ul>
        <a href="<%= backend_identities_path %>" data-navigable-item>
          Identities
          <span is-="badge" variant-="background2" cap-="round" style="float: right;">IDNT</span>
        </a>
        <a href="<%= backend_audit_logs_path %>" data-navigable-item>
          Audit logs
          <span is-="badge" variant-="background2" cap-="round" style="float: right;">LOGS</span>
        </a>
      </ul>

      <div is-="separator"></div>

      <ul>
        <a href="#" onclick="window.openKbar && window.openKbar(); return false;" data-navigable-item>
          Go anywhere
          <span style="float: right; color: var(--overlay0);"><kbd>⌘K</kbd></span>
        </a>
      </ul>

      <div is-="separator"></div>

      <ul>
        <a href="<%= root_path %>" data-navigable-item>
          Escape hatch
          <span is-="badge" variant-="background2" cap-="round" style="float: right;">EXIT</span>
        </a>
      </ul>
    </column>

    <div is-="separator"></div>

    <row gap-="2" align-="center" pad-="1 0" style="color: var(--overlay0);">
      <span><kbd>j</kbd> <kbd>k</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>⌘K</kbd> search</span>
    </row>
  </column>
</column>

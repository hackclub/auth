<div class="tui-page" style="display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 4lh);">
  <article box-="round" style="min-width:60ch;max-width:80ch;">
    <h2>HCA // BACKEND</h2>
    <div is-="separator"></div>
    <div style="color:var(--overlay1);padding:0.5lh 0;">
      <%= current_user.display_name %> · <%= current_user.pretty_roles %>
    </div>
    <div is-="separator"></div>
    <div data-navigable-list>
      <% if current_user.super_admin? %>
        <div style="color:var(--overlay0);padding:0.5lh 0 0;">Super admin</div>
        <div data-navigable-item>
          <a href="<%= backend_flipper_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Flipper</b> <i style="color:var(--overlay0)">(i hardly know 'er!)</i></span>
            <span class="tui-item-badge"><span is-="badge">FLIP</span></span>
          </a>
        </div>
        <div data-navigable-item>
          <a href="<%= backend_audits1984_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Audits1984</b></span>
            <span class="tui-item-badge"><span is-="badge">ORWL</span></span>
          </a>
        </div>
        <div data-navigable-item>
          <a href="<%= backend_good_job_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Job queue</b></span>
            <span class="tui-item-badge"><span is-="badge">JOBS</span></span>
          </a>
        </div>
        <div data-navigable-item>
          <a href="<%= backend_users_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Manage users</b></span>
            <span class="tui-item-badge"><span is-="badge">USRS</span></span>
          </a>
        </div>
      <% end %>

      <% if current_user&.program_manager? || current_user&.super_admin? %>
        <div is-="separator"></div>
        <div style="color:var(--overlay0);padding:0.5lh 0 0;">Program manager</div>
        <div data-navigable-item>
          <a href="<%= developer_apps_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Manage OAuth2 apps</b></span>
            <span class="tui-item-badge"><span is-="badge">APPS</span></span>
          </a>
        </div>
      <% end %>

      <% if current_user&.manual_document_verifier? || current_user&.super_admin? %>
        <div is-="separator"></div>
        <div style="color:var(--overlay0);padding:0.5lh 0 0;">Document verifier</div>
        <div data-navigable-item>
          <a href="<%= pending_backend_verifications_path %>" class="tui-item">
            <span class="tui-item-icon">⭢</span>
            <span class="tui-item-text"><b>Review pending verifications</b></span>
            <span class="tui-item-badge"><span is-="badge" variant-="peach">PEND</span></span>
          </a>
        </div>
      <% end %>

      <div is-="separator"></div>
      <div data-navigable-item>
        <a href="<%= backend_identities_path %>" class="tui-item">
          <span class="tui-item-icon">⭢</span>
          <span class="tui-item-text"><b>Identities</b></span>
          <span class="tui-item-badge"><span is-="badge">IDNT</span></span>
        </a>
      </div>
      <div data-navigable-item>
        <a href="<%= backend_audit_logs_path %>" class="tui-item">
          <span class="tui-item-icon">⭢</span>
          <span class="tui-item-text"><b>Audit logs</b></span>
          <span class="tui-item-badge"><span is-="badge">LOGS</span></span>
        </a>
      </div>

      <div is-="separator"></div>
      <div data-navigable-item>
        <a href="#" onclick="window.openKbar && window.openKbar(); return false;" class="tui-item">
          <span class="tui-item-icon">⊹</span>
          <span class="tui-item-text"><b>Go anywhere</b></span>
          <span class="tui-item-badge"><kbd>⌘K</kbd></span>
        </a>
      </div>
      <div is-="separator"></div>
      <div data-navigable-item>
        <a href="<%= root_path %>" class="tui-item">
          <span class="tui-item-icon">⭠</span>
          <span class="tui-item-text"><b>Escape hatch</b></span>
          <span class="tui-item-badge"><span is-="badge">EXIT</span></span>
        </a>
      </div>
    </div>
    <div is-="separator"></div>
    <div class="tui-keyhints">
      <span><kbd>j</kbd>/<kbd>k</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>⌘K</kbd> search</span>
    </div>
  </article>
</div>

<column self-="grow" align-="center center" style="min-height: calc(100vh - 3lh);">
  <column box-="round" style="min-width: 56ch; max-width: 72ch; --box-border-color: var(--foreground2);">
    <row align-="center between">
      <span is-="badge" variant-="lavender">HCA</span>
      <span style="color: var(--subtext0);"><%= current_user.display_name %> · <%= current_user.pretty_roles %></span>
    </row>

    <div is-="separator"></div>

    <column data-navigable-list>
      <% if current_user.super_admin? %>
        <span style="color: var(--subtext0); padding: 0 1ch;">Super admin</span>
        <ul>
          <%= render_nav_item backend_flipper_path, "Flipper", "FLIP", sub: "(i hardly know 'er!)" %>
          <%= render_nav_item backend_audits1984_path, "Audits1984", "ORWL" %>
          <%= render_nav_item backend_good_job_path, "Job queue", "JOBS" %>
          <%= render_nav_item backend_users_path, "Manage users", "USRS" %>
        </ul>
      <% end %>

      <% if current_user&.program_manager? || current_user&.super_admin? %>
        <span style="color: var(--subtext0); padding: 0 1ch;">Program manager</span>
        <ul>
          <%= render_nav_item developer_apps_path, "Manage OAuth2 apps", "APPS" %>
        </ul>
      <% end %>

      <% if current_user&.manual_document_verifier? || current_user&.super_admin? %>
        <span style="color: var(--subtext0); padding: 0 1ch;">Document verifier</span>
        <ul>
          <%= render_nav_item pending_backend_verifications_path, "Review pending", "PEND", variant: "peach" %>
        </ul>
      <% end %>

      <div is-="separator"></div>

      <%= render_nav_item backend_identities_path, "Identities", "IDNT" %>
      <%= render_nav_item backend_audit_logs_path, "Audit logs", "LOGS" %>

      <div is-="separator"></div>

      <a href="#" onclick="window.openKbar && window.openKbar(); return false;" data-navigable-item>
        <span style="flex: 1;">Go anywhere</span>
        <span style="color: var(--subtext0);"><kbd>⌘K</kbd></span>
      </a>

      <div is-="separator"></div>

      <%= render_nav_item root_path, "Escape hatch", "EXIT" %>
    </column>

    <div is-="separator"></div>

    <row gap-="2" align-="center center" pad-="1 0" style="color: var(--overlay1);">
      <row gap-="1" align-="center">
        <button size-="small" variant-="background2" onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'ArrowUp', bubbles: true}))">↑</button>
        <button size-="small" variant-="background2" onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'ArrowDown', bubbles: true}))">↓</button>
        navigate
      </row>
      <row gap-="1" align-="center">
        <button size-="small" variant-="background2" onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'Enter', bubbles: true}))">↵</button>
        open
      </row>
      <row gap-="1" align-="center">
        <button size-="small" variant-="background2" onclick="window.openKbar && window.openKbar()">⌘K</button>
        search
      </row>
    </row>
  </column>
</column>

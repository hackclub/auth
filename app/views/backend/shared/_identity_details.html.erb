<%
  show_legal_name = local_assigns.fetch(:show_legal_name, false)
%>
<div style="font-family:monospace;">
  <%= render identity %>

  <% if identity.legal_first_name.present? && show_legal_name %>
    <div class="tui-detail">
      <span class="tui-detail-label">legal name</span>
      <span class="tui-detail-value"><%= identity.legal_first_name %> <%= identity.legal_last_name %></span>
    </div>
  <% end %>
  <div class="tui-detail">
    <span class="tui-detail-label">country</span>
    <span class="tui-detail-value"><%= identity.country %></span>
  </div>
  <div class="tui-detail">
    <span class="tui-detail-label">email</span>
    <span class="tui-detail-value"><%= identity.primary_email %></span>
  </div>
  <div class="tui-detail">
    <span class="tui-detail-label">birthday</span>
    <span class="tui-detail-value"><%= identity.birthday %></span>
  </div>
  <div class="tui-detail">
    <span class="tui-detail-label">phone</span>
    <span class="tui-detail-value"><%= identity.phone_number %></span>
  </div>
  <div class="tui-detail">
    <span class="tui-detail-label">status</span>
    <span class="tui-detail-value"><%= identity.verification_status.humanize %></span>
  </div>
  <% if defined?(identity.ysws_eligible) && !identity.ysws_eligible.nil? %>
    <div class="tui-detail">
      <span class="tui-detail-label">ysws</span>
      <span class="tui-detail-value"><%= identity.ysws_eligible ? "eligible" : "ineligible" %></span>
    </div>
  <% end %>
  <div class="tui-detail">
    <span class="tui-detail-label">slack</span>
    <span class="tui-detail-value">
      <% if identity.slack_id.present? %>
        <%= link_to identity.slack_id, "https://hackclub.slack.com/team/#{identity.slack_id}" %>
      <% else %>
        <i>not set</i>
      <% end %>
    </span>
  </div>
</div>

<%
  current_shortcode = Shortcodes.find_by_route(controller_path, action_name, current_user)
%>
<div id="toolbar">
  <div class="action_bar">
    <div class="action_bar_left">
      <span class="usn">Hack Club Auth</span>
      <%= yield %>
    </div>
    <div class="action_bar_right">
      <% if current_shortcode.present? %>
        <span class="current_shortcode">[<%= current_shortcode.code %>]</span>
      <% end %>
      <%= render "backend/shared/action_button", hotkey: "?", onclick: "window.openHints()" do %>KBD SHORTCUTS<% end %>
      <%= render "backend/shared/action_button", hotkey: "\u2318K", onclick: "window.openKbar()" do %>GO<% end %>
    </div>
  </div>
</div>

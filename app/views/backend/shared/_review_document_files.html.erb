<% if document.files.attached? %>
  <div class="document-files">
    <% document.files.each_with_index do |file, index| %>
      <div class="document-file">
        <div class="file-header">
          <span class="file-name"><%= index + 1 %>. <%= file.filename %></span>
          <%= link_to "open \u2197", url_for(file), target: "_blank", class: "file-action" %>
        </div>
        <% if file.content_type.start_with?("image/") %>
          <%
            image_src = if file.content_type.in?(%w[image/heic image/heif])
              url_for(file.variant(format: :png))
            else
              url_for(file)
            end
          %>
          <div class="file-preview">
            <div id="loader-<%= index %>" class="file-loader">
              <%= file.content_type.in?(%w[image/heic image/heif]) ? "converting heic..." : "loading..." %>
              <br>
              <%= vite_image_tag "images/loader.gif", class: "loader-gif" %>
            </div>
            <div id="image-container-<%= index %>" class="image-container hidden">
              <%= image_tag image_src,
                alt: "document file #{index + 1}",
                class: "preview-image",
                id: "image-#{index}",
                data: { rotation: 0 },
                onload: "document.getElementById('loader-#{index}').style.display='none'; document.getElementById('image-container-#{index}').classList.remove('hidden');",
                onerror: "document.getElementById('loader-#{index}').innerHTML='error loading image';" %>
              <button type="button" class="action_button rotate-button" onclick="rotateImage(<%= index %>)">&#8635; rotate</button>
            </div>
          </div>
        <% elsif file.content_type == "application/pdf" %>
          <div class="file-preview pdf-preview">
            <iframe src="<%= url_for(file) %>" class="pdf-frame" type="application/pdf">
              <p class="pdf-fallback">
                browser doesn't support pdf embedding.
                <%= link_to "open pdf", url_for(file), target: "_blank" %>
              </p>
            </iframe>
          </div>
        <% else %>
          <div class="file-preview lowered">
            <div class="detail-row">
              <span class="detail-label">type</span>
              <span class="detail-value"><%= file.content_type %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">download</span>
              <span class="detail-value"><%= link_to "download file", url_for(file), target: "_blank" %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
  <script>
    function rotateImage(index) {
      const img = document.getElementById('image-' + index);
      let currentRotation = parseInt(img.dataset.rotation || 0);
      currentRotation = (currentRotation + 90);
      img.dataset.rotation = currentRotation;
      img.style.transform = 'rotate(' + currentRotation + 'deg)';
    }
  </script>
<% else %>
  <div class="empty-state">no files attached</div>
<% end %>

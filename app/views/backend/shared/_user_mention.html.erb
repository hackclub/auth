<span class="user-mention">
  <% case user %>
  <% when Backend::User %>
    <%= link_to backend_user_path(user) do %><%= user.username %><%= " \u26A1" if user.super_admin? %><% end %>
  <% when Identity %>
    <%= link_to backend_identity_path(user) do %><%= user.first_name %> <%= user.last_name %><% end %>
  <% end %>
</span>

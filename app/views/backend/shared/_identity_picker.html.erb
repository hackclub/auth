<%
  picker_name = local_assigns.fetch(:name, nil)
  picker_multiple = local_assigns.fetch(:multiple, false)
  picker_required = local_assigns.fetch(:required, false)
  picker_placeholder = local_assigns.fetch(:placeholder, nil)
  picker_selected = local_assigns.fetch(:selected, nil)

  picker_name ||= picker_multiple ? "identity_ids" : "identity_id"
  picker_placeholder ||= picker_multiple ? "Search to add..." : "Search identities..."

  formatted_selected = if picker_multiple
    Array(picker_selected).map { |s|
      case s
      when Identity then { id: s.public_id, label: s.full_name, sublabel: s.primary_email }
      when Hash then s.slice(:id, :label, :sublabel)
      else { id: s.to_s, label: s.to_s, sublabel: nil }
      end
    }
  elsif picker_selected
    case picker_selected
    when Identity then { id: picker_selected.public_id, label: picker_selected.full_name, sublabel: picker_selected.primary_email }
    when Hash then picker_selected.slice(:id, :label, :sublabel)
    else { id: picker_selected.to_s, label: picker_selected.to_s, sublabel: nil }
    end
  end
%>
<div data-identity-picker>
  <script type="application/json" class="picker-initial-data">
    <%= raw({
      name: picker_name,
      multiple: picker_multiple,
      required: picker_required,
      placeholder: picker_placeholder,
      selected: formatted_selected
    }.to_json) %>
  </script>
</div>

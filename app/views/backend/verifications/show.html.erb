<% content_for :title, "Document Review" %>
<column pad-="2 1" style="max-width: 120ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2>document review</h2>
    <row gap-="2" align-="center">
      <% if @verification.respond_to?(:persona_dashboard_url) && @verification.persona_dashboard_url %>
        <% super_admin_tool(element: "span") do %>
          <a href="<%= @verification.persona_dashboard_url %>" target="_blank" style="color: var(--foreground2);">persona ↗</a>
        <% end %>
      <% end %>
      <a href="<%= pending_backend_verifications_path %>" style="color: var(--foreground2); text-decoration: none;">← back to pending</a>
    </row>
  </row>

  <div is-="separator"></div>

  <%# === Identity + Document side by side === %>
  <row gap-="3" align-="start" style="flex-wrap: wrap;">
    <column style="flex: 1; min-width: 30ch;">
      <span style="color: var(--foreground2); font-style: italic;">identity</span>
      <column box-="square">
        <%= render "backend/shared/review_basic_details", identity: @verification.identity %>
      </column>
    </column>

    <column style="flex: 1; min-width: 30ch;">
      <span style="color: var(--foreground2); font-style: italic;">document</span>
      <column box-="square">
        <%= render @verification.review_info_partial, verification: @verification %>
      </column>
    </column>
  </row>

  <%# === Warnings === %>
  <% if @verification.identity.birthday && @verification.identity.birthday < 19.years.ago %>
    <%= render Components::Backend::Banner.new(kind: :warning) do %>birthday (<%= @verification.identity.birthday %>) is more than 19 years ago<% end %>
  <% end %>

  <% if @verification.identity.tombstone_collisions.any? %>
    <%= render Components::Backend::Banner.new(kind: :error) do %>
      POTENTIAL TOMBSTONE COLLISION — please check in with Nora before you approve this verification.
      <details style="margin-top: 0.5lh;">
        <summary style="cursor: pointer; color: inherit;">show details</summary>
        <p>This person matches <%= pluralize(@verification.identity.tombstone_collisions.size, "deleted record") %>:</p>
        <% @verification.identity.tombstone_collisions.includes(:deletion).each do |collision| %>
          <div style="padding: 0.25lh 0;">
            <b>deleted identity</b>: <%= collision.deletion.privacy_request_reference.presence || "no reference" %>
            <span style="opacity: 0.7;">(tombstoned <%= time_ago_in_words(collision.deletion.created_at) %> ago)</span>
          </div>
        <% end %>
      </details>
    <% end %>
  <% end %>

  <% if @verification.identity.resemblances.any? %>
    <%= render Components::Backend::Banner.new(kind: :warning) do %>
      POSSIBLE DUPLICATE — <%= pluralize(@verification.identity.resemblances.size, "match") %>
      <details style="margin-top: 0.5lh;">
        <summary style="cursor: pointer; color: inherit;">show resemblances</summary>
        <% @verification.identity.resemblances.each do |resemblance| %>
          <div style="padding: 0.25lh 0;">
            <b><%= resemblance.title %></b>: <%= resemblance.current_label %> matches
            <% if resemblance.past_identity %>
              <%= link_to resemblance.matched_label, backend_identity_path(resemblance.past_identity), target: "_blank", style: "color: inherit; text-decoration: underline;" %>
            <% else %>
              [deleted]
            <% end %>
            <% if resemblance.matched_verification %>
              (<%= link_to "verification", backend_verification_path(resemblance.matched_verification), target: "_blank", style: "color: inherit; text-decoration: underline;" %>)
            <% end %>
          </div>
        <% end %>
      </details>
    <% end %>
  <% end %>

  <% if @verification.respond_to?(:issues) && @verification.issues.any? %>
    <%= render Components::Backend::Banner.new(kind: :info) do %>
      automated checks:
      <% @verification.issues.each do |issue| %>
        <br>· <%= issue %>
      <% end %>
    <% end %>
  <% end %>

  <div is-="separator"></div>

  <%# === Files === %>
  <span style="color: var(--foreground2); font-style: italic;">files</span>
  <% if @relevant_object.nil? %>
    <column box-="square" style="color: var(--foreground2);">no files yet — awaiting persona completion</column>
  <% elsif @verification.needs_break_glass? %>
    <%= render "backend/shared/break_the_glass", break_glassable: @relevant_object, auto_break_glass: (@verification.pending? ? "to review validity" : nil) do %>
      <%= render @verification.review_full_partial, record: @relevant_object %>
    <% end %>
  <% else %>
    <%= render @verification.review_full_partial, verification: @verification %>
  <% end %>

  <div is-="separator"></div>

  <%# === Decision bar === %>
  <% if @verification.draft? %>
    <column box-="square">
      <row gap-="2" align-="center">
        <span>status: <span is-="badge">draft</span></span>
        <span style="color: var(--foreground2);">user hasn't completed persona yet</span>
      </row>
    </column>
  <% elsif @verification.pending? %>
    <column gap-="1">
      <row align-="center" gap-="2" style="flex-wrap: wrap;">
        <% mdv_tool(element: "span") do %>
          <%= form_with url: approve_backend_verification_path(@verification), method: :patch, local: true, style: "display:inline" do |form| %>
            <%= form.hidden_field :ysws_eligible, value: true %>
            <button type="submit" variant-="green" size-="small">[a] APPROVE YSWS</button>
          <% end %>
          <%= form_with url: approve_backend_verification_path(@verification), method: :patch, local: true, style: "display:inline" do |form| %>
            <%= form.hidden_field :ysws_eligible, value: false %>
            <button type="submit" variant-="yellow" size-="small">[A] APPROVE NOT YSWS</button>
          <% end %>
        <% end %>

        <row gap-="1" align-="center" style="margin-left: auto;">
          <span>status: <span is-="badge" variant-="yellow">pending</span></span>
          <% if @verification.identity.ysws_eligible.nil? %>
            <span>ysws: <span is-="badge">not reviewed</span></span>
          <% elsif @verification.identity.ysws_eligible %>
            <span>ysws: <span is-="badge" variant-="green">eligible</span></span>
          <% else %>
            <span>ysws: <span is-="badge" variant-="red">ineligible</span></span>
          <% end %>
        </row>
      </row>

      <div is-="separator"></div>

      <% mdv_tool do %>
        <%= form_with url: reject_backend_verification_path(@verification), method: :patch, local: true do |form| %>
          <% if @verification.identity.under_13? %>
            <%= render Components::Backend::Banner.new(kind: :warning) do %>identity is under 13 (age <%= @verification.identity.age.round(2) %>)<% end %>
          <% end %>
          <row gap-="2" align-="start" style="flex-wrap: wrap;">
            <column style="min-width: 16ch;">
              <%= form.label :rejection_reason, "[r] reason" %>
              <% options = @verification.rejection_reason_options %>
              <%= form.select :rejection_reason,
                             grouped_options_for_select([
                               ["Retryable", options[:retryable]],
                               ["Fatal", options[:fatal]]
                             ], @verification.default_rejection_reason),
                             { include_blank: "select..." } %>
            </column>
            <column style="flex: 1; min-width: 16ch;">
              <%= form.label :rejection_reason_details, "details" %>
              <%= form.text_area :rejection_reason_details, rows: 2, placeholder: "feedback for user..." %>
            </column>
            <column style="flex: 1; min-width: 16ch;">
              <%= form.label :internal_rejection_comment, "internal" %>
              <%= form.text_area :internal_rejection_comment, rows: 2, placeholder: "internal notes (not visible to user)..." %>
            </column>
            <column style="align-self: flex-end;">
              <button type="submit" variant-="red" size-="small" onclick="return confirm('reject this document?')">REJECT</button>
            </column>
          </row>
        <% end %>
      <% end %>
    </column>
  <% else %>
    <%# Already processed %>
    <column box-="square">
      <span style="color: var(--foreground2); font-style: italic;">processed</span>
      <row gap-="2" align-="center">
        <span>status: <span is-="badge" variant-="<%= @verification.approved? ? 'green' : 'red' %>"><%= @verification.status %></span></span>
        <% if @verification.rejection_reason.present? %>
          <span>reason: <b><%= @verification.rejection_reason_name %></b></span>
        <% end %>
      </row>
      <% if @verification.rejection_reason_details.present? %>
        <row>
          <span style="min-width: 12ch; color: var(--foreground2);">details</span>
          <span><%= @verification.rejection_reason_details %></span>
        </row>
      <% end %>
      <% if @verification.internal_rejection_comment.present? %>
        <row>
          <span style="min-width: 12ch; color: var(--foreground2);">internal</span>
          <i><%= @verification.internal_rejection_comment %></i>
        </row>
      <% end %>
    </column>
  <% end %>

  <% if @verification.ignored_at.present? %>
    <div is-="separator"></div>
    <column box-="square">
      <row gap-="2" align-="center">
        <span is-="badge" variant-="yellow">ignored</span>
        <span style="color: var(--foreground2);"><%= @verification.ignored_at.strftime("%B %d, %Y at %I:%M %p") %></span>
      </row>
      <row>
        <span style="min-width: 12ch; color: var(--foreground2);">reason</span>
        <span><%= @verification.ignored_reason %></span>
      </row>
    </column>
  <% elsif @verification.ignored_at.blank? %>
    <% super_admin_tool do %>
      <div is-="separator"></div>
      <%= form_with url: ignore_backend_verification_path(@verification), method: :patch, local: true do |f| %>
        <column gap-="1">
          <%= f.label :reason, "ignore reason" %>
          <%= f.text_area :reason, placeholder: "reason for ignoring (logged in audit trail)...", rows: 2 %>
          <%= f.submit "ignore verification", data: { confirm: "ignore this verification? this cannot be undone." } %>
        </column>
      <% end %>
      <% if @verification.is_a?(Verification::PersonaVerification) && (@verification.draft? || @verification.pending?) %>
        <div is-="separator"></div>
        <%= button_to "nuke inquiry & start fresh",
              nuke_inquiry_backend_verification_path(@verification),
              method: :delete,
              data: { confirm: "destroy this verification and its persona inquiry? the user will get a fresh inquiry on their next visit." },
              style: "color: var(--red);" %>
      <% end %>
    <% end %>
  <% end %>

  <div is-="separator"></div>

  <details>
    <summary style="color: var(--foreground2); cursor: pointer;">audit log</summary>
    <column pad-="1 0">
      <%= render "backend/shared/activity_log", activities: @activities %>
    </column>
  </details>

  <div is-="separator"></div>

  <row gap-="2" align-="center" style="color: var(--foreground2);">
    <% if @verification.pending? %>
      <row gap-="1" align-="center">
        <span is-="badge" variant-="background2">a</span>
        approve ysws
      </row>
      <row gap-="1" align-="center">
        <span is-="badge" variant-="background2">A</span>
        approve not ysws
      </row>
      <row gap-="1" align-="center">
        <span is-="badge" variant-="background2">r</span>
        reject
      </row>
    <% end %>
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">Bksp</span>
      back
    </row>
  </row>
</column>

<%= render "backend/shared/inspector", record: @verification %>
<% if @relevant_object %>
  <%= render "backend/shared/inspector", record: @relevant_object %>
<% end %>

<column pad-="2 1" style="max-width: 120ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <row gap-="2" align-="center">
      <h2>pending (<%= @pending_verifications.total_count %>)</h2>
      <% if @average_hangtime.present? %>
        <span style="color: var(--foreground2);">avg wait: <%= distance_of_time_in_words(0, @average_hangtime) %></span>
      <% end %>
    </row>
    <a href="<%= backend_verifications_path %>" style="color: var(--foreground2); text-decoration: none;">all verifications →</a>
  </row>

  <div is-="separator"></div>

  <% if @pending_verifications.any? %>
    <column data-navigable-list box-="square" shear-="both" style="--box-border-color: var(--background2);">
      <% @pending_verifications.each_with_index do |verification, i| %>
        <%
          wait_seconds = (Time.current - (verification.pending_at || verification.created_at)).to_i
          urgency = if wait_seconds > 86400 then "red"
                    elsif wait_seconds > 21600 then "yellow"
                    else nil end
          has_dupes = verification.identity.resemblances.any?
        %>
        <% if i > 0 %><div is-="separator"></div><% end %>
        <a href="<%= backend_verification_path(verification) %>" data-navigable-item style="padding: 0.5lh 1ch;">
          <span style="flex: 1;">
            <b><%= verification.document_type %></b>
            · <%= verification.identity.first_name %> <%= verification.identity.last_name %>
            <% if has_dupes %>
              <span style="color: var(--yellow);">⚠</span>
            <% end %>
          </span>
          <row gap-="1" align-="center">
            <span style="<%= urgency ? "color: var(--#{urgency});" : "color: var(--foreground2);" %>">
              <%= time_ago_in_words(verification.pending_at || verification.created_at) %>
            </span>
            <% if verification.identity.country.present? %>
              <span is-="badge" variant-="background2"><%= verification.identity.country %></span>
            <% end %>
          </row>
        </a>
      <% end %>
    </column>

    <div is-="separator"></div>
    <%= paginate @pending_verifications %>
  <% else %>
    <column align-="center center" pad-="2 2" style="color: var(--foreground2);">
      no documents pending verification
    </column>
  <% end %>

  <div is-="separator"></div>

  <row gap-="2" align-="center" style="color: var(--foreground2);">
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">↑</span>
      <span is-="badge" variant-="background2">↓</span>
      navigate
    </row>
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">↵</span>
      review
    </row>
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">n</span>
      <span is-="badge" variant-="background2">p</span>
      page
    </row>
    <row gap-="1" align-="center">
      <span is-="badge" variant-="background2">Bksp</span>
      back
    </row>
  </row>
</column>

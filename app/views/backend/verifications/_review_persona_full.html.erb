<column>
  <% doc = record&.verification&.identity_document %>
  <% if doc&.files&.attached? %>
    <%= render "backend/shared/review_document_files", record: doc %>
    <div is-="separator" style="margin: 1lh 0;"></div>
  <% end %>

  <% if record&.checks&.any? %>
    <span style="color: var(--foreground2); font-style: italic;">persona checks</span>
    <table>
      <thead>
        <tr><th>check</th><th>status</th><th>requirement</th><th>reasons</th></tr>
      </thead>
      <tbody>
        <% record.checks.each do |check| %>
          <tr>
            <td><%= check["name"].to_s.tr("_", " ") %></td>
            <td>
              <span is-="badge" variant-="<%= check["status"] == "passed" ? "green" : check["status"] == "failed" ? "red" : "" %>"><%= check["status"] %></span>
            </td>
            <td style="color: var(--foreground2);"><%= check["requirement"] %></td>
            <td style="color: var(--foreground2);"><%= check["reasons"]&.compact&.join(", ").presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% super_admin_tool do %>
    <% if record&.respond_to?(:doc_json) %>
      <details>
        <summary style="cursor: pointer; color: var(--foreground2);">raw persona response</summary>
        <pre style="white-space: pre-wrap; font-size: 0.85em; padding: 1lh 0;"><%= JSON.pretty_generate(record.doc_json) %></pre>
      </details>
    <% end %>
  <% end %>
</column>

<column pad-="2 1" style="max-width: 120ch; margin: 0 auto; width: 100%;">
  <row align-="center between">
    <h2>dashboard</h2>
    <%= form_tag backend_dashboard_path, method: :get, style: "display:inline;" do %>
      <%= select_tag :time_period,
          options_for_select([
            ["today", "today"],
            ["this month", "this_month"],
            ["all time", "all_time"]
          ], @time_period),
          onchange: "this.form.submit()" %>
    <% end %>
  </row>

  <div is-="separator"></div>

  <%# Hero: pending count %>
  <row align-="center center" gap-="2" pad-="1 1">
    <column align-="center center">
      <span style="font-size: 2em; font-weight: bold;"><%= @stats[:pending] %></span>
      <span style="color: var(--foreground2);">pending</span>
    </column>
  </row>

  <row align-="center center" gap-="3" style="color: var(--foreground2);">
    <span><b><%= @stats[:total] %></b> total</span>
    <span><b style="color: var(--green);"><%= @stats[:approved] %></b> approved</span>
    <span><b style="color: var(--red);"><%= @stats[:rejected] %></b> rejected</span>
    <span>avg wait: <b><%= distance_of_time_in_words 0, (@stats[:average_hangtime] || 0) %></b></span>
  </row>

  <div is-="separator"></div>

  <%# Two-column: leaderboard + rejection reasons %>
  <row gap-="3" align-="start">
    <column style="flex: 1;">
      <span style="color: var(--foreground2); font-style: italic;">leaderboard</span>
      <% if @leaderboard.any? %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>user</th>
              <th>processed</th>
            </tr>
          </thead>
          <tbody>
            <% @leaderboard.each_with_index do |entry, index| %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= render entry[:user] %></td>
                <td><b><%= entry[:processed_count] %></b></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <span style="color: var(--foreground2);">no activity yet</span>
      <% end %>
    </column>

    <column style="flex: 1;">
      <span style="color: var(--foreground2); font-style: italic;">rejection reasons</span>
      <% if @rejection_breakdown.any? %>
        <table>
          <thead>
            <tr>
              <th>reason</th>
              <th>count</th>
              <th>%</th>
            </tr>
          </thead>
          <tbody>
            <% total_rejected = @stats[:rejected] %>
            <% @rejection_breakdown.each do |reason, data| %>
              <tr>
                <td>
                  <%= reason %>
                  <% if data[:fatal] %><span is-="badge" variant-="red">fatal</span><% end %>
                </td>
                <td><b><%= data[:count] %></b></td>
                <td><%= total_rejected > 0 ? "#{(data[:count].to_f / total_rejected * 100).round(1)}%" : "0%" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <span style="color: var(--foreground2);">no rejections</span>
      <% end %>
    </column>
  </row>

  <div is-="separator"></div>

  <span style="color: var(--foreground2); font-style: italic;">rejections by country</span>
  <% if @rejections_by_country.any? %>
    <table>
      <thead>
        <tr>
          <th>country</th>
          <th>fatal</th>
          <th>total</th>
          <th>fatal %</th>
          <th>breakdown</th>
        </tr>
      </thead>
      <tbody>
        <% @rejections_by_country.each do |country, data| %>
          <% next if data[:fatal] == 0 %>
          <tr>
            <td><b><%= country %></b></td>
            <td style="color: var(--red);"><b><%= data[:fatal] %></b></td>
            <td><%= data[:total] %></td>
            <td>
              <% if data[:fatal_rate] >= 50 %>
                <span is-="badge" variant-="red"><%= data[:fatal_rate] %>%</span>
              <% elsif data[:fatal_rate] >= 25 %>
                <span is-="badge" variant-="yellow"><%= data[:fatal_rate] %>%</span>
              <% else %>
                <%= data[:fatal_rate] %>%
              <% end %>
            </td>
            <td>
              <details>
                <summary style="color: var(--foreground2);">view</summary>
                <% data[:reasons].each do |reason, r| %>
                  <span><%= reason %>: <%= r[:count] %><% if r[:fatal] %> <span is-="badge" variant-="red">fatal</span><% end %></span><br>
                <% end %>
              </details>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <span style="color: var(--foreground2);">none</span>
  <% end %>
</column>
